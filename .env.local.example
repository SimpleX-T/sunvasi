# ============================================================================
# Sunvasi — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the new "publishable" key (sb_publishable_…) from Project Settings → API.
# The legacy NEXT_PUBLIC_SUPABASE_ANON_KEY is still accepted as a fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Privy (client identity) -----------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Only set these to "true" if you've enabled the matching method in the Privy
# Dashboard (User Management → Authentication methods). Email is always on.
NEXT_PUBLIC_PRIVY_GOOGLE_LOGIN=
NEXT_PUBLIC_PRIVY_WALLET_LOGIN=

# --- Cloudinary (deliverable storage) --------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=sunvasi/dev

# --- Gemini (AI arbitrator) ------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro

# --- Trustless Work --------------------------------------------------------
# Network: testnet | mainnet
TRUSTLESS_WORK_NETWORK=testnet
TRUSTLESS_WORK_API_KEY=
# Stellar Passkey Kit (freelancer-side wallet, used if TW chain is Stellar)
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_LAUNCHTUBE_URL=
LAUNCHTUBE_JWT=
NEXT_PUBLIC_MERCURY_URL=
MERCURY_JWT=

# --- Resend (outbound email — optional; falls back to mailto: if unset) ----
RESEND_API_KEY=
RESEND_FROM="Sunvasi <hello@sunvasi.app>"

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
